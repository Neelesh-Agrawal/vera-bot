PORT=8787
HOST=0.0.0.0
TEAM_NAME=YourName
TEAM_MEMBER=YourName
CONTACT_EMAIL=you@example.com

LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3.6-27b

# Judge simulator only (local testing — not needed on deploy)
JUDGE_GROQ_MODEL=llama-3.3-70b-versatile
# JUDGE_GROQ_API_KEY=

# Set to 1 while debugging template fallbacks
DEBUG_LLM=0

# Keep Groq connection warm after deploy (set 0 to disable)
WARMUP_LLM=1

# Judge timeout budget — stay under 30s per testing-brief §5
TICK_DEADLINE_MS=28000
REPLY_DEADLINE_MS=28000
COMPOSE_TIMEOUT_MS=22000
