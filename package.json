{
  "name": "vera-bot",
  "version": "2.0.0",
  "description": "magicpin AI Challenge - Vera message composer bot",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "load-dataset": "tsx src/scripts/loadDataset.ts",
    "generate-submission": "tsx src/scripts/generateSubmission.ts",
    "reencode-submission": "tsx src/scripts/reencodeSubmission.ts",
    "stress-test": "tsx src/scripts/stressTest.ts",
    "judge": "python judge_simulator.py",
    "judge-replay": "python judge_simulator.py --replay-only",
    "multi-turn": "tsx src/scripts/multiTurnReplay.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  }
}
